<mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />
    <mxCell id="title" parent="1" style="text;html=1;align=left;fontSize=14;fontStyle=1;" value="Panel 3 zoom — 1 warp&#39;s 2×4 register tile: outer-product reuse and its register cost (held across all 32 lanes)" vertex="1"><mxGeometry x="20" y="12" width="1100" height="22" as="geometry" /></mxCell>
    <mxCell id="sub" parent="1" style="text;html=1;align=left;fontSize=10;fontColor=#555;fontStyle=2;" value="Same outer product as a scalar SGEMM micro-tile — but each &#34;scalar&#34; is now a 16×16 fragment spread over the warp, so it costs 4–8 registers/lane instead of 1." vertex="1"><mxGeometry x="20" y="34" width="1100" height="16" as="geometry" /></mxCell>

    <!-- ===================== LEFT: outer-product grid ===================== -->
    <mxCell id="glab" parent="1" style="text;html=1;align=center;fontSize=11;fontStyle=1;" value="The 2×4 outer product:  c[i][j] += a[i] · b[j]" vertex="1"><mxGeometry x="40" y="62" width="430" height="16" as="geometry" /></mxCell>

    <!-- corner cell -->
    <mxCell id="corner" parent="1" style="whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=8;fontColor=#888;align=center;" value="32 lanes&#10;cooperate" vertex="1"><mxGeometry x="40" y="90" width="70" height="60" as="geometry" /></mxCell>

    <!-- B fragments across the top (4 cols, half) -->
    <mxCell id="b0" parent="1" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#118a4b;strokeWidth=2;fontSize=9;fontColor=#0b4f29;" value="b[0]&#10;16×16&#10;half" vertex="1"><mxGeometry x="120" y="90" width="70" height="60" as="geometry" /></mxCell>
    <mxCell id="b1" parent="1" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#118a4b;strokeWidth=2;fontSize=9;fontColor=#0b4f29;" value="b[1]&#10;16×16&#10;half" vertex="1"><mxGeometry x="195" y="90" width="70" height="60" as="geometry" /></mxCell>
    <mxCell id="b2" parent="1" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#118a4b;strokeWidth=2;fontSize=9;fontColor=#0b4f29;" value="b[2]&#10;16×16&#10;half" vertex="1"><mxGeometry x="270" y="90" width="70" height="60" as="geometry" /></mxCell>
    <mxCell id="b3" parent="1" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#118a4b;strokeWidth=2;fontSize=9;fontColor=#0b4f29;" value="b[3]&#10;16×16&#10;half" vertex="1"><mxGeometry x="345" y="90" width="70" height="60" as="geometry" /></mxCell>

    <!-- A fragments down the left (2 rows, half) -->
    <mxCell id="a0" parent="1" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#118a4b;strokeWidth=2;fontSize=9;fontColor=#0b4f29;" value="a[0]&#10;16×16&#10;half" vertex="1"><mxGeometry x="40" y="160" width="70" height="60" as="geometry" /></mxCell>
    <mxCell id="a1" parent="1" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#118a4b;strokeWidth=2;fontSize=9;fontColor=#0b4f29;" value="a[1]&#10;16×16&#10;half" vertex="1"><mxGeometry x="40" y="225" width="70" height="60" as="geometry" /></mxCell>

    <!-- C accumulators 2x4 (float) -->
    <mxCell id="c00" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;strokeWidth=2;fontSize=9;fontColor=#1d4f8b;" value="c[0][0]" vertex="1"><mxGeometry x="120" y="160" width="70" height="60" as="geometry" /></mxCell>
    <mxCell id="c01" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;strokeWidth=2;fontSize=9;fontColor=#1d4f8b;" value="c[0][1]" vertex="1"><mxGeometry x="195" y="160" width="70" height="60" as="geometry" /></mxCell>
    <mxCell id="c02" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;strokeWidth=2;fontSize=9;fontColor=#1d4f8b;" value="c[0][2]" vertex="1"><mxGeometry x="270" y="160" width="70" height="60" as="geometry" /></mxCell>
    <mxCell id="c03" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;strokeWidth=2;fontSize=9;fontColor=#1d4f8b;" value="c[0][3]" vertex="1"><mxGeometry x="345" y="160" width="70" height="60" as="geometry" /></mxCell>
    <mxCell id="c10" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;strokeWidth=2;fontSize=9;fontColor=#1d4f8b;" value="c[1][0]" vertex="1"><mxGeometry x="120" y="225" width="70" height="60" as="geometry" /></mxCell>
    <mxCell id="c11" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;strokeWidth=2;fontSize=9;fontColor=#1d4f8b;" value="c[1][1]" vertex="1"><mxGeometry x="195" y="225" width="70" height="60" as="geometry" /></mxCell>
    <mxCell id="c12" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;strokeWidth=2;fontSize=9;fontColor=#1d4f8b;" value="c[1][2]" vertex="1"><mxGeometry x="270" y="225" width="70" height="60" as="geometry" /></mxCell>
    <mxCell id="c13" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;strokeWidth=2;fontSize=9;fontColor=#1d4f8b;" value="c[1][3]" vertex="1"><mxGeometry x="345" y="225" width="70" height="60" as="geometry" /></mxCell>

    <!-- reuse guide arrows: a[i] feeds its row, b[j] feeds its column -->
    <mxCell id="ra0" parent="1" style="endArrow=none;html=1;strokeColor=#118a4b;dashed=1;strokeWidth=1;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="110" y="190" as="sourcePoint" /><mxPoint x="415" y="190" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="ra1" parent="1" style="endArrow=none;html=1;strokeColor=#118a4b;dashed=1;strokeWidth=1;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="110" y="255" as="sourcePoint" /><mxPoint x="415" y="255" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="rb0" parent="1" style="endArrow=none;html=1;strokeColor=#118a4b;dashed=1;strokeWidth=1;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="155" y="150" as="sourcePoint" /><mxPoint x="155" y="285" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="rb1" parent="1" style="endArrow=none;html=1;strokeColor=#118a4b;dashed=1;strokeWidth=1;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="230" y="150" as="sourcePoint" /><mxPoint x="230" y="285" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="rb2" parent="1" style="endArrow=none;html=1;strokeColor=#118a4b;dashed=1;strokeWidth=1;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="305" y="150" as="sourcePoint" /><mxPoint x="305" y="285" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="rb3" parent="1" style="endArrow=none;html=1;strokeColor=#118a4b;dashed=1;strokeWidth=1;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="380" y="150" as="sourcePoint" /><mxPoint x="380" y="285" as="targetPoint" /></mxGeometry></mxCell>

    <mxCell id="gnote" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#555;" value="6 input fragments (2 a + 4 b) → 8 outputs.  Each a[i] is reused across 4 cols; each b[j] across 2 rows.&#10;That reuse is exactly why a warp blocks 2×4 tiles instead of computing 1 tile per load (which would be memory-bound)." vertex="1"><mxGeometry x="40" y="295" width="430" height="40" as="geometry" /></mxCell>

    <!-- ===================== RIGHT TOP: one fragment → registers ===================== -->
    <mxCell id="flab" parent="1" style="text;html=1;align=center;fontSize=11;fontStyle=1;" value="Where does 1 fragment live? → registers, split over 32 lanes" vertex="1"><mxGeometry x="500" y="62" width="380" height="16" as="geometry" /></mxCell>

    <mxCell id="fragbox" parent="1" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#118a4b;strokeWidth=2;fontSize=9;fontColor=#0b4f29;align=center;" value="1 fragment = 16×16 = 256 elements&#10;(no single thread owns it)" vertex="1"><mxGeometry x="510" y="90" width="190" height="56" as="geometry" /></mxCell>
    <mxCell id="splitar" parent="1" style="endArrow=classic;html=1;strokeColor=#444;strokeWidth=2;fontSize=8;" value="÷ 32 lanes" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="700" y="118" as="sourcePoint" /><mxPoint x="760" y="118" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="lanebox" parent="1" style="whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#666;strokeWidth=2;fontSize=9;align=left;spacingLeft=8;" value="per lane:&#10;• half  (a/b): 8 halves = &lt;b&gt;4 regs&lt;/b&gt;&#10;• float (c)  : 8 floats = &lt;b&gt;8 regs&lt;/b&gt;" vertex="1"><mxGeometry x="762" y="86" width="190" height="64" as="geometry" /></mxCell>

    <!-- ===================== RIGHT MID: register tally ===================== -->
    <mxCell id="tlab" parent="1" style="text;html=1;align=center;fontSize=11;fontStyle=1;" value="Register cost of the whole 2×4 warp tile (per lane)" vertex="1"><mxGeometry x="500" y="160" width="452" height="16" as="geometry" /></mxCell>

    <mxCell id="trow_h" parent="1" style="whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#90a4ae;fontSize=9;fontStyle=1;align=left;spacingLeft=8;" value="fragment array            count × regs/lane = regs/lane" vertex="1"><mxGeometry x="500" y="180" width="452" height="22" as="geometry" /></mxCell>
    <mxCell id="trow_a" parent="1" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#118a4b;fontSize=9;align=left;spacingLeft=8;fontColor=#0b4f29;" value="a[2]   matrix_a, half          2 × 4   =   8" vertex="1"><mxGeometry x="500" y="202" width="452" height="22" as="geometry" /></mxCell>
    <mxCell id="trow_b" parent="1" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#118a4b;fontSize=9;align=left;spacingLeft=8;fontColor=#0b4f29;" value="b[4]   matrix_b, half          4 × 4   =   16" vertex="1"><mxGeometry x="500" y="224" width="452" height="22" as="geometry" /></mxCell>
    <mxCell id="trow_c" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=9;align=left;spacingLeft=8;fontColor=#1d4f8b;fontStyle=1;" value="c[2][4]  accumulator, float    8 × 8   =   64   ← dominant" vertex="1"><mxGeometry x="500" y="246" width="452" height="22" as="geometry" /></mxCell>
    <mxCell id="trow_t" parent="1" style="whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;fontSize=10;align=left;spacingLeft=8;fontColor=#7c3a06;fontStyle=1;" value="fragments subtotal ≈ 88 regs/lane   (+ loop/index/pointers → ~100+)" vertex="1"><mxGeometry x="500" y="268" width="452" height="24" as="geometry" /></mxCell>

    <mxCell id="caprow" parent="1" style="whiteSpace=wrap;html=1;fillColor=#fde0e0;strokeColor=#c0392b;fontSize=9;align=left;spacingLeft=8;fontColor=#7b241c;" value="Bump to c[4][4] → 16 accumulators = 128 regs/lane → spills / occupancy collapses.&#10;THIS register pressure is why the warp tile is 2×4, not larger." vertex="1"><mxGeometry x="500" y="295" width="452" height="40" as="geometry" /></mxCell>

    <!-- ===================== BOTTOM: scalar vs tensor-core contrast ===================== -->
    <mxCell id="cmplab" parent="1" style="text;html=1;align=left;fontSize=11;fontStyle=1;" value="Why it feels different from CUDA-core SGEMM — same pattern, heavier &quot;element&quot;:" vertex="1"><mxGeometry x="20" y="350" width="700" height="18" as="geometry" /></mxCell>

    <mxCell id="scalarbox" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;spacingRight=10;" value="&lt;b&gt;Scalar (CUDA core)&lt;/b&gt;&#10;1 thread does the FMA. An operand &#34;row&#34; or &#34;col&#34; is a single &lt;b&gt;scalar = 1 register&lt;/b&gt;. To get reuse, 1 thread blocks an 8×8 micro-tile: 8 a-scalars + 8 b-scalars (16 regs) feed 64 accumulators (64 regs). Cheap inputs, so blocking up is easy." vertex="1"><mxGeometry x="20" y="372" width="455" height="92" as="geometry" /></mxCell>
    <mxCell id="tcbox" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#b45309;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;spacingRight=10;" value="&lt;b&gt;Tensor Core (WMMA)&lt;/b&gt;&#10;A &lt;b&gt;warp&lt;/b&gt; does one 16×16×16 MMA. Each operand is a whole &lt;b&gt;fragment&lt;/b&gt; — 256 elements spread over the 32 lanes = &lt;b&gt;4–8 regs/lane&lt;/b&gt;, not 1. Same outer-product reuse (2 a + 4 b → 8 c), but the 8 float accumulators alone are 64 regs/lane → that&#39;s the budget ceiling." vertex="1"><mxGeometry x="497" y="372" width="455" height="92" as="geometry" /></mxCell>
  </root>
</mxGraphModel>
