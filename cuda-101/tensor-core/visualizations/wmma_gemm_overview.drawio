    <mxCell id="pa4" parent="1" style="endArrow=classic;html=1;strokeColor=#444;fontSize=8;" value="α·c, store_matrix_sync&#10;→ SMEM → D" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="734" y="350" as="sourcePoint" /><mxPoint x="820" y="350" as="targetPoint" /></mxGeometry></mxCell>
