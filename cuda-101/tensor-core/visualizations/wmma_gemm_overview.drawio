    <!-- ===================== WMMA definition bar ===================== -->
    <mxCell id="wmmadef" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede7f6;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;WMMA = Warp-level Matrix Multiply-Accumulate&lt;/b&gt; (the &lt;i&gt;nvcuda::wmma&lt;/i&gt; C++ API in &lt;i&gt;mma.h&lt;/i&gt;). It exposes the GPU's &lt;b&gt;Tensor Cores&lt;/b&gt;: a whole &lt;b&gt;warp&lt;/b&gt; (32 threads) cooperates to compute one small fixed-size matrix multiply D = A·B + C in a single hardware op. Tiles here are 16×16×16. Data lives in opaque &lt;b&gt;fragment&lt;/b&gt; objects (registers, layout hidden); you only call &lt;b&gt;fill_fragment&lt;/b&gt;, &lt;b&gt;load_matrix_sync&lt;/b&gt;, &lt;b&gt;mma_sync&lt;/b&gt;, &lt;b&gt;store_matrix_sync&lt;/b&gt;. Inputs are FP16, accumulation is FP32 — far higher throughput than scalar FMA." vertex="1"><mxGeometry x="20" y="400" width="922" height="64" as="geometry" /></mxCell>
  </root>
</mxGraphModel>
