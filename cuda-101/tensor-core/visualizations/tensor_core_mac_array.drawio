<mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />
    <mxCell id="title" parent="1" style="text;html=1;align=left;fontSize=14;fontStyle=1;" value="How a Tensor Core computes a 16×16×16 tile: scalar FMA loop  vs  a hard-wired MAC array" vertex="1"><mxGeometry x="20" y="12" width="1000" height="22" as="geometry" /></mxCell>

    <!-- ===================== top: the math ===================== -->
    <mxCell id="f_d" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;strokeWidth=2;fontSize=8;fontColor=#1d4f8b;" value="D&#10;16×16&#10;float" vertex="1"><mxGeometry x="30" y="48" width="56" height="56" as="geometry" /></mxCell>
    <mxCell id="eq1" parent="1" style="text;html=1;align=center;fontSize=16;fontStyle=1;" value="=" vertex="1"><mxGeometry x="88" y="64" width="20" height="24" as="geometry" /></mxCell>
    <mxCell id="f_a" parent="1" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#118a4b;strokeWidth=2;fontSize=8;fontColor=#0b4f29;" value="A&#10;16×16&#10;half" vertex="1"><mxGeometry x="110" y="48" width="56" height="56" as="geometry" /></mxCell>
    <mxCell id="eq2" parent="1" style="text;html=1;align=center;fontSize=16;fontStyle=1;" value="×" vertex="1"><mxGeometry x="168" y="64" width="20" height="24" as="geometry" /></mxCell>
    <mxCell id="f_b" parent="1" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#118a4b;strokeWidth=2;fontSize=8;fontColor=#0b4f29;" value="B&#10;16×16&#10;half" vertex="1"><mxGeometry x="190" y="48" width="56" height="56" as="geometry" /></mxCell>
    <mxCell id="eq3" parent="1" style="text;html=1;align=center;fontSize=16;fontStyle=1;" value="+" vertex="1"><mxGeometry x="248" y="64" width="20" height="24" as="geometry" /></mxCell>
    <mxCell id="f_c" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;strokeWidth=2;fontSize=8;fontColor=#1d4f8b;" value="C&#10;16×16&#10;float" vertex="1"><mxGeometry x="270" y="48" width="56" height="56" as="geometry" /></mxCell>
    <mxCell id="mathnote" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;D[i][j] = C[i][j] + Σ&lt;sub&gt;k=0..15&lt;/sub&gt; A[i][k]·B[k][j]&lt;/b&gt;&#10;= 16 · 16 · 16 = &lt;b&gt;4096 multiply-adds&lt;/b&gt; for one tile." vertex="1"><mxGeometry x="350" y="48" width="360" height="56" as="geometry" /></mxCell>

    <!-- ===================== left: scalar path ===================== -->
    <mxCell id="sclab" parent="1" style="text;html=1;align=left;fontSize=12;fontStyle=1;fontColor=#b45309;" value="Scalar path — CUDA core" vertex="1"><mxGeometry x="30" y="135" width="320" height="18" as="geometry" /></mxCell>
    <mxCell id="scbox" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#999;dashed=1;" value="" vertex="1"><mxGeometry x="30" y="160" width="330" height="290" as="geometry" /></mxCell>

    <mxCell id="scmac" parent="1" style="whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;strokeWidth=2;fontSize=10;fontColor=#7c3a06;" value="1 MAC unit&#10;d = a·b + d" vertex="1"><mxGeometry x="130" y="245" width="120" height="70" as="geometry" /></mxCell>
    <mxCell id="scloop" parent="1" style="endArrow=classic;startArrow=classic;html=1;rounded=1;strokeColor=#b45309;strokeWidth=2;exitX=1;exitY=0.5;entryX=1;entryY=0.2;" edge="1" source="scmac" target="scmac"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="300" y="280" /><mxPoint x="300" y="220" /></Array></mxGeometry></mxCell>
    <mxCell id="sclooplab" parent="1" style="text;html=1;align=left;fontSize=10;fontColor=#b45309;fontStyle=1;" value="repeat&#10;4096×" vertex="1"><mxGeometry x="305" y="240" width="50" height="30" as="geometry" /></mxCell>
    <mxCell id="scin" parent="1" style="text;html=1;align=center;fontSize=9;fontColor=#555;" value="one a, one b&#10;per step" vertex="1"><mxGeometry x="130" y="210" width="120" height="28" as="geometry" /></mxCell>
    <mxCell id="scnote" parent="1" style="text;html=1;align=left;fontSize=10;fontColor=#555;" value="• 4096 separate FMA instructions, &lt;b&gt;sequential&lt;/b&gt; per thread.&#10;• Each pays the overhead: fetch / decode /&#10;&#160;&#160;schedule / register read+write — the multiply&#10;&#160;&#160;itself is the cheap part.&#10;• A warp does it 32-wide, but still ~thousands&#10;&#160;&#160;of issued ops to finish the tile." vertex="1"><mxGeometry x="45" y="335" width="305" height="100" as="geometry" /></mxCell>

    <!-- ===================== right: tensor core MAC array ===================== -->
    <mxCell id="tclab" parent="1" style="text;html=1;align=left;fontSize=12;fontStyle=1;fontColor=#2563eb;" value="Tensor Core — hard-wired MAC array (systolic)" vertex="1"><mxGeometry x="430" y="135" width="500" height="18" as="geometry" /></mxCell>
    <mxCell id="tcbox" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#2563eb;dashed=1;" value="" vertex="1"><mxGeometry x="430" y="160" width="710" height="290" as="geometry" /></mxCell>

    <!-- B operands enter from the top (columns) -->
    <mxCell id="blab" parent="1" style="text;html=1;align=center;fontSize=9;fontColor=#118a4b;fontStyle=1;" value="B columns stream DOWN  (B[k][j], over k = 0..15)" vertex="1"><mxGeometry x="600" y="178" width="280" height="14" as="geometry" /></mxCell>
    <mxCell id="bd0" parent="1" style="endArrow=classic;html=1;strokeColor=#118a4b;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="624" y="220" as="sourcePoint" /><mxPoint x="624" y="248" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="bd1" parent="1" style="endArrow=classic;html=1;strokeColor=#118a4b;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="674" y="220" as="sourcePoint" /><mxPoint x="674" y="248" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="bd2" parent="1" style="endArrow=classic;html=1;strokeColor=#118a4b;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="724" y="220" as="sourcePoint" /><mxPoint x="724" y="248" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="bd3" parent="1" style="endArrow=classic;html=1;strokeColor=#118a4b;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="774" y="220" as="sourcePoint" /><mxPoint x="774" y="248" as="targetPoint" /></mxGeometry></mxCell>

    <!-- A operands enter from the left (rows) -->
    <mxCell id="alab" parent="1" style="text;html=1;align=center;fontSize=9;fontColor=#118a4b;fontStyle=1;verticalAlign=middle;rotation=-90;" value="A rows stream RIGHT  (A[i][k], over k = 0..15)" vertex="1"><mxGeometry x="448" y="290" width="240" height="14" as="geometry" /></mxCell>
    <mxCell id="ar0" parent="1" style="endArrow=classic;html=1;strokeColor=#118a4b;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="572" y="274" as="sourcePoint" /><mxPoint x="600" y="274" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="ar1" parent="1" style="endArrow=classic;html=1;strokeColor=#118a4b;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="572" y="324" as="sourcePoint" /><mxPoint x="600" y="324" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="ar2" parent="1" style="endArrow=classic;html=1;strokeColor=#118a4b;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="572" y="374" as="sourcePoint" /><mxPoint x="600" y="374" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="ar3" parent="1" style="endArrow=classic;html=1;strokeColor=#118a4b;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="572" y="424" as="sourcePoint" /><mxPoint x="600" y="424" as="targetPoint" /></mxGeometry></mxCell>

    <!-- the PE grid 4x4 -->
    <mxCell id="pe00" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[0][0]" vertex="1"><mxGeometry x="600" y="250" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe01" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[0][1]" vertex="1"><mxGeometry x="650" y="250" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe02" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[0][2]" vertex="1"><mxGeometry x="700" y="250" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe03" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[0][3]" vertex="1"><mxGeometry x="750" y="250" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe10" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[1][0]" vertex="1"><mxGeometry x="600" y="300" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe11" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[1][1]" vertex="1"><mxGeometry x="650" y="300" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe12" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[1][2]" vertex="1"><mxGeometry x="700" y="300" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe13" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[1][3]" vertex="1"><mxGeometry x="750" y="300" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe20" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[2][0]" vertex="1"><mxGeometry x="600" y="350" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe21" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[2][1]" vertex="1"><mxGeometry x="650" y="350" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe22" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[2][2]" vertex="1"><mxGeometry x="700" y="350" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe23" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[2][3]" vertex="1"><mxGeometry x="750" y="350" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe30" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[3][0]" vertex="1"><mxGeometry x="600" y="400" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe31" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[3][1]" vertex="1"><mxGeometry x="650" y="400" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe32" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[3][2]" vertex="1"><mxGeometry x="700" y="400" width="48" height="48" as="geometry" /></mxCell>
    <mxCell id="pe33" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=7;fontColor=#1d4f8b;" value="MAC&#10;D[3][3]" vertex="1"><mxGeometry x="750" y="400" width="48" height="48" as="geometry" /></mxCell>

    <mxCell id="tcnote" parent="1" style="text;html=1;align=left;fontSize=10;fontColor=#555;" value="(shown 4×4 — the real array&#10;does the full 16×16 = 256 cells)&#10;&#10;• Every cell = a multiply-add unit&#10;&#160;&#160;wired permanently to its neighbours.&#10;• A flows →, B flows ↓; where row i&#10;&#160;&#160;meets column j they meet at cell (i,j),&#10;&#160;&#160;which accumulates Σ&lt;sub&gt;k&lt;/sub&gt; A[i][k]·B[k][j].&#10;• The k-loop and the sum are in &lt;b&gt;silicon&lt;/b&gt;&#10;&#160;&#160;— no instruction issued per multiply.&#10;• All 256 cells work at once → the whole&#10;&#160;&#160;tile in a few pipelined HMMA ops." vertex="1"><mxGeometry x="830" y="240" width="300" height="200" as="geometry" /></mxCell>

    <!-- ===================== bottom: warp-cooperative + why ===================== -->
    <mxCell id="sumbar" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede7f6;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;Why it's &amp;quot;one instruction&amp;quot;:&lt;/b&gt;&amp;nbsp; the 4096 multiply-adds are not issued one by one — they are baked into a fixed grid of MAC units. &lt;b&gt;wmma::mma_sync&lt;/b&gt; is a &lt;b&gt;warp-cooperative&lt;/b&gt; op: all 32 lanes hand their slices of the A/B &lt;b&gt;fragments&lt;/b&gt; (held in registers) into this shared hardware together; it computes the whole tile and scatters D back across the warp's registers. &lt;b&gt;Fixed 16×16×16&lt;/b&gt; is precisely what lets the wiring be permanent and overhead-free — that's the throughput win over the scalar loop on the left." vertex="1"><mxGeometry x="30" y="465" width="1100" height="56" as="geometry" /></mxCell>
  </root>
</mxGraphModel>
