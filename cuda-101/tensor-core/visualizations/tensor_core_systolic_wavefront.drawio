    <mxCell id="p3_B0" parent="1" style="text;html=1;align=center;fontSize=7;fontColor=#118a4b;fontStyle=1;" value="B30↓" vertex="1"><mxGeometry x="909" y="100" width="34" height="14" as="geometry" /></mxCell>
    <mxCell id="p3_B1" parent="1" style="text;html=1;align=center;fontSize=7;fontColor=#118a4b;fontStyle=1;" value="B21↓" vertex="1"><mxGeometry x="941" y="100" width="34" height="14" as="geometry" /></mxCell>
    <mxCell id="p3_B2" parent="1" style="text;html=1;align=center;fontSize=7;fontColor=#118a4b;fontStyle=1;" value="B12↓" vertex="1"><mxGeometry x="973" y="100" width="34" height="14" as="geometry" /></mxCell>
    <mxCell id="p3_B3" parent="1" style="text;html=1;align=center;fontSize=7;fontColor=#118a4b;fontStyle=1;" value="B03↓" vertex="1"><mxGeometry x="1005" y="100" width="34" height="14" as="geometry" /></mxCell>

    <!-- ===== mechanism inset: inside one cell ===== -->
    <mxCell id="mlab" parent="1" style="text;html=1;align=left;fontSize=11;fontStyle=1;" value="Inside one MAC cell (i,j):" vertex="1"><mxGeometry x="20" y="296" width="240" height="18" as="geometry" /></mxCell>
    <mxCell id="mcell" parent="1" style="whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#bf9000;strokeWidth=2;fontSize=9;fontColor=#7f6000;" value="(i,j)&#10;D += A·B" vertex="1"><mxGeometry x="110" y="340" width="100" height="54" as="geometry" /></mxCell>
    <mxCell id="mAin" parent="1" style="endArrow=classic;html=1;strokeColor=#118a4b;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="60" y="367" as="sourcePoint" /><mxPoint x="110" y="367" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="mAinL" parent="1" style="text;html=1;align=center;fontSize=8;fontColor=#118a4b;" value="A[i][k]" vertex="1"><mxGeometry x="40" y="346" width="60" height="14" as="geometry" /></mxCell>
    <mxCell id="mAout" parent="1" style="endArrow=classic;html=1;strokeColor=#118a4b;strokeWidth=2;dashed=1;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="210" y="367" as="sourcePoint" /><mxPoint x="270" y="367" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="mAoutL" parent="1" style="text;html=1;align=center;fontSize=8;fontColor=#118a4b;" value="forward → (i,j+1)" vertex="1"><mxGeometry x="214" y="346" width="100" height="14" as="geometry" /></mxCell>
    <mxCell id="mBin" parent="1" style="endArrow=classic;html=1;strokeColor=#118a4b;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="160" y="310" as="sourcePoint" /><mxPoint x="160" y="340" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="mBinL" parent="1" style="text;html=1;align=left;fontSize=8;fontColor=#118a4b;" value="B[k][j]" vertex="1"><mxGeometry x="166" y="312" width="60" height="14" as="geometry" /></mxCell>
    <mxCell id="mBout" parent="1" style="endArrow=classic;html=1;strokeColor=#118a4b;strokeWidth=2;dashed=1;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="160" y="394" as="sourcePoint" /><mxPoint x="160" y="424" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="mBoutL" parent="1" style="text;html=1;align=left;fontSize=8;fontColor=#118a4b;" value="forward ↓ (i+1,j)" vertex="1"><mxGeometry x="166" y="404" width="110" height="14" as="geometry" /></mxCell>

    <!-- ===== legend ===== -->
    <mxCell id="lgsw1" parent="1" style="whiteSpace=wrap;html=1;fillColor=#ffe599;strokeColor=#bf9000;strokeWidth=2;" value="" vertex="1"><mxGeometry x="360" y="300" width="16" height="16" as="geometry" /></mxCell>
    <mxCell id="lgtx1" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#555;" value="&lt;b&gt;just activated&lt;/b&gt; — fires its k=0 term this cycle (the wavefront)" vertex="1"><mxGeometry x="382" y="299" width="420" height="16" as="geometry" /></mxCell>
    <mxCell id="lgsw2" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;" value="" vertex="1"><mxGeometry x="360" y="322" width="16" height="16" as="geometry" /></mxCell>
    <mxCell id="lgtx2" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#555;" value="&lt;b&gt;accumulating&lt;/b&gt; — already started, adds its next k term (k = t − i − j) each cycle" vertex="1"><mxGeometry x="382" y="321" width="460" height="16" as="geometry" /></mxCell>
    <mxCell id="lgsw3" parent="1" style="whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;" value="" vertex="1"><mxGeometry x="360" y="344" width="16" height="16" as="geometry" /></mxCell>
    <mxCell id="lgtx3" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#555;" value="&lt;b&gt;idle&lt;/b&gt; — its operands (A from the left, B from above) have not reached it yet (i+j &gt; t)" vertex="1"><mxGeometry x="382" y="343" width="470" height="16" as="geometry" /></mxCell>
    <mxCell id="lgnote" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#777;" value="Notation in cells = D[i][j]. Edge labels Aik = A[i][k], Bkj = B[k][j]. Shown 4×4; the real Tensor-Core tile is 16×16 (t runs 0…30)." vertex="1"><mxGeometry x="360" y="368" width="540" height="28" as="geometry" /></mxCell>

    <!-- ===== bottom explanation bar ===== -->
    <mxCell id="bar" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede7f6;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;Output-stationary array:&lt;/b&gt; each cell (i,j) keeps its accumulator D[i][j]. Every cycle it multiply-adds the &lt;b style=&quot;color:#118a4b&quot;&gt;A&lt;/b&gt; arriving from its left and the &lt;b style=&quot;color:#118a4b&quot;&gt;B&lt;/b&gt; arriving from above, then &lt;b&gt;forwards that A to the right and that B downward&lt;/b&gt; — so one loaded value is reused across a whole row / column (no re-fetch). Because A flows → and B flows ↓ at the same time, cells light up along &lt;b style=&quot;color:#bf9000&quot;&gt;anti-diagonals i+j = t&lt;/b&gt;, exactly as you described. Once the pipeline fills, every cell runs every cycle → the full 16×16 tile in a few pipelined HMMA ops, not 4096 separate instructions. (Conceptual model — NVIDIA's exact internal dataflow is undisclosed.)" vertex="1"><mxGeometry x="20" y="430" width="1120" height="70" as="geometry" /></mxCell>
  </root>
</mxGraphModel>
