    <mxCell id="anote" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#999;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" value="4096 useful MACs spread over 46 cycles on 256 cells → only &lt;b&gt;~35% average&lt;/b&gt;. Fill never finishes ramping before drain begins, so it &lt;b&gt;never hits 100%&lt;/b&gt; (peak ~75%)." vertex="1"><mxGeometry x="800" y="120" width="330" height="70" as="geometry" /></mxCell>

