    <mxCell id="b100lab" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#cc0000;fontStyle=1;" value="100%" vertex="1"><mxGeometry x="888" y="393" width="50" height="14" as="geometry" /></mxCell>

    <!-- utilization envelope: trapezoid, flat top at 100% -->
    <mxCell id="benv" parent="1" style="shape=trapezoid;perimeter=trapezoidPerimeter;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#118a4b;strokeWidth=2;opacity=70;size=0.09;" value="" vertex="1"><mxGeometry x="150" y="400" width="700" height="120" as="geometry" /></mxCell>
