    <mxCell id="bdrainlab" parent="1" style="text;html=1;align=center;fontSize=9;fontColor=#b45309;fontStyle=1;" value="drain&#10;once" vertex="1"><mxGeometry x="830" y="455" width="50" height="28" as="geometry" /></mxCell>

    <!-- gantt: overlapping tiles -->
    <mxCell id="gtitle" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#555;fontStyle=2;" value="each tile's 46-cycle life overlaps its neighbours:" vertex="1"><mxGeometry x="150" y="535" width="320" height="14" as="geometry" /></mxCell>
    <mxCell id="gt1" parent="1" style="whiteSpace=wrap;html=1;rounded=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=8;fontColor=#1d4f8b;" value="tile N" vertex="1"><mxGeometry x="150" y="552" width="230" height="12" as="geometry" /></mxCell>
    <mxCell id="gt2" parent="1" style="whiteSpace=wrap;html=1;rounded=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=8;fontColor=#1d4f8b;" value="N+1" vertex="1"><mxGeometry x="210" y="566" width="230" height="12" as="geometry" /></mxCell>
    <mxCell id="gt3" parent="1" style="whiteSpace=wrap;html=1;rounded=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=8;fontColor=#1d4f8b;" value="N+2" vertex="1"><mxGeometry x="270" y="580" width="230" height="12" as="geometry" /></mxCell>
    <mxCell id="gt4" parent="1" style="whiteSpace=wrap;html=1;rounded=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=8;fontColor=#1d4f8b;" value="N+3" vertex="1"><mxGeometry x="330" y="594" width="230" height="12" as="geometry" /></mxCell>
    <mxCell id="gt5" parent="1" style="whiteSpace=wrap;html=1;rounded=1;fillColor=#eaf2fd;strokeColor=#9bbef8;fontSize=8;fontColor=#6c8ebf;" value="…" vertex="1"><mxGeometry x="390" y="608" width="230" height="12" as="geometry" /></mxCell>
    <mxCell id="goverlap" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#118a4b;fontStyle=1;" value="N+1 fills the cells N is draining → no idle gap" vertex="1"><mxGeometry x="565" y="566" width="300" height="14" as="geometry" /></mxCell>

    <!-- ====================================================== bottom bar ====================================================== -->
    <mxCell id="bar" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede7f6;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;Takeaway:&lt;/b&gt; a lone 16×16×16 op pays ~15 cycles to &lt;b style=&quot;color:#118a4b&quot;&gt;fill&lt;/b&gt; the array and ~15 to &lt;b style=&quot;color:#b45309&quot;&gt;drain&lt;/b&gt; it, so the wavefront leaves most cells idle (≈35% average, ≈75% peak). In a real GEMM the kernel streams &lt;b&gt;millions&lt;/b&gt; of tiles (the K-loop × all output tiles); each tile reuses the cells the previous one is vacating, the fill/drain happen &lt;b&gt;once&lt;/b&gt; at the very start/end, and steady-state utilization approaches 100%. That is exactly why keeping the Tensor Core fed (shared-memory tiling, operand reuse, no stalls) is the whole game. (Conceptual systolic model — NVIDIA's real microarchitecture is undisclosed.)" vertex="1"><mxGeometry x="20" y="635" width="1120" height="74" as="geometry" /></mxCell>
  </root>
</mxGraphModel>
