    <!-- Arrow: B col → both threads -->
    <mxCell id="p2ba1" parent="1" style="endArrow=classic;html=1;strokeColor=#b45309;strokeWidth=1;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="174" y="274" as="sourcePoint" /><mxPoint x="174" y="280" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="p2ba2" parent="1" style="endArrow=classic;html=1;strokeColor=#b45309;strokeWidth=1;dashed=1;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="200" y="266" as="sourcePoint" /><mxPoint x="200" y="380" as="targetPoint" /></mxGeometry></mxCell>
