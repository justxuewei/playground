    <mxCell id="s1" parent="1" style="text;html=1;align=left;fontSize=9;" value="&lt;b&gt;1.&lt;/b&gt; Each thread computes &lt;b&gt;8 C elements&lt;/b&gt;,&#10;     takes &lt;b&gt;8 A&lt;/b&gt; + &lt;b&gt;1 B&lt;/b&gt; per dotIdx step." vertex="1">
      <mxGeometry x="450" y="80" width="480" height="30" as="geometry" />
    </mxCell>
    <mxCell id="s2" parent="1" style="text;html=1;align=left;fontSize=9;" value="&lt;b&gt;2.&lt;/b&gt; &lt;b&gt;2 warps&lt;/b&gt; process one C row group (64 cols)." vertex="1">
      <mxGeometry x="450" y="120" width="480" height="14" as="geometry" />
    </mxCell>
    <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;fontSize=9;align=left;" value="" vertex="1">
      <mxGeometry x="450" y="144" width="480" height="50" as="geometry" />
    </mxCell>
    <mxCell id="s3t" parent="1" style="text;html=1;align=left;fontSize=9;" value="&lt;b&gt;3.&lt;/b&gt; Same row group  →  &lt;font color=&quot;#2563eb&quot;&gt;&lt;b&gt;same A&lt;/b&gt;&lt;/font&gt; (shared)&#10;                       →  &lt;font color=&quot;#b45309&quot;&gt;&lt;b&gt;different B&lt;/b&gt;&lt;/font&gt; (1 col per thread)" vertex="1">
      <mxGeometry x="458" y="148" width="464" height="42" as="geometry" />
    </mxCell>
    <mxCell id="s4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c2185b;strokeWidth=1;fontSize=9;align=left;" value="" vertex="1">
      <mxGeometry x="450" y="204" width="480" height="50" as="geometry" />
    </mxCell>
    <mxCell id="s4t" parent="1" style="text;html=1;align=left;fontSize=9;" value="&lt;b&gt;4.&lt;/b&gt; Same column  →  &lt;font color=&quot;#2563eb&quot;&gt;&lt;b&gt;different A&lt;/b&gt;&lt;/font&gt; (1 row group each)&#10;                  →  &lt;font color=&quot;#b45309&quot;&gt;&lt;b&gt;same B&lt;/b&gt;&lt;/font&gt; (shared col)" vertex="1">
      <mxGeometry x="458" y="208" width="464" height="42" as="geometry" />
    </mxCell>

    <mxCell id="sn" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#666;fontStyle=2;" value="↑ The sharing patterns are why register tiling (TM=8) is efficient:&#10;a thread reuses As in registers across 8 outputs, and Bs across 8 dotIdx steps." vertex="1">
      <mxGeometry x="450" y="270" width="480" height="40" as="geometry" />
    </mxCell>

