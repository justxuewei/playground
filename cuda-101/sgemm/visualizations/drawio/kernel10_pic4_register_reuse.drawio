    <mxCell id="k10reads" parent="1" style="text;html=1;align=left;fontSize=10;fontStyle=1;fontColor=#6c8ebf;" value="loads: regM[16] + regN[8] = 24 reads" vertex="1"><mxGeometry x="558" y="396" width="360" height="16" as="geometry" /></mxCell>
    <mxCell id="k10fmas" parent="1" style="text;html=1;align=left;fontSize=10;fontStyle=1;fontColor=#118a4b;" value="FMAs: 16×8 = 128 (across 4 subtiles)" vertex="1"><mxGeometry x="558" y="414" width="360" height="16" as="geometry" /></mxCell>
    <mxCell id="k10ai" parent="1" style="text;html=1;align=left;fontSize=11;fontStyle=1;" value="AI = 128 / 24 = 5.33 FMA/read" vertex="1"><mxGeometry x="558" y="432" width="360" height="18" as="geometry" /></mxCell>
    <mxCell id="note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;The point:&lt;/b&gt; both load regM/regN once per dotIdx, then reuse each value across a whole row/column of the outer product. Kernel 10 stretches the register slab to span &lt;b&gt;WMITER×WNITER subtiles&lt;/b&gt;, so 24 reads feed 128 FMAs (vs kernel 6's 16→64). Each regM is reused 8× (one per regN), each regN reused 16× (one per regM) → arithmetic intensity rises, now amortized at the warp level." vertex="1"><mxGeometry x="20" y="470" width="980" height="52" as="geometry" /></mxCell>
  </root>
