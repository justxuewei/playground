    <mxCell id="s_note" parent="1" style="text;html=1;align=left;fontSize=8;fontColor=#a35200;fontStyle=1;" value="As[(innerColA*4+j)*BM + innerRowA] → col m=2, rows k=4..7" vertex="1"><mxGeometry x="470" y="270" width="152" height="16" as="geometry" /></mxCell>
    <mxCell id="e_rs" parent="1" style="endArrow=classic;html=1;strokeColor=#d79b00;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="408" y="201.0" as="sourcePoint" /><mxPoint x="514" y="178" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="e_rs_l" parent="1" style="text;html=1;align=center;fontSize=8;fontColor=#d79b00;fontStyle=1;" value="scatter: each component&#10;to a different As row (stride BM)" vertex="1"><mxGeometry x="410" y="200" width="170" height="28" as="geometry" /></mxCell>
    <mxCell id="note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;Why transpose?&lt;/b&gt; In A the 4 floats lie &lt;b&gt;horizontally&lt;/b&gt; (along K) → one vectorized float4 GMEM load. Storing them &lt;b&gt;vertically&lt;/b&gt; in As (K becomes the major axis) makes the later read &lt;font face=&quot;monospace&quot;&gt;As[dotIdx*BM + threadRow*TM + i]&lt;/font&gt; contiguous along BM, so the compiler can vectorize the SMEM load too." vertex="1"><mxGeometry x="20" y="330" width="760" height="52" as="geometry" /></mxCell>
  </root>
