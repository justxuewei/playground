    <mxCell id="rowarr" parent="1" style="endArrow=none;html=1;strokeColor=#2563eb;strokeWidth=1;dashed=1;" value="" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="192" y="255" as="sourcePoint" /><mxPoint x="384" y="255" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="rownote" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#2563eb;" value="&lt;b&gt;m2 loaded once&lt;/b&gt;, reused in&#10;all TN cells of its row&#10;→ &lt;b&gt;TN FMAs per load&lt;/b&gt;" vertex="1"><mxGeometry x="396" y="228" width="250" height="40" as="geometry" /></mxCell>
    <mxCell id="colarr" parent="1" style="endArrow=none;html=1;strokeColor=#D6B656;strokeWidth=1;dashed=1;" value="" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="269" y="132" as="sourcePoint" /><mxPoint x="269" y="324" as="targetPoint" /></mxGeometry></mxCell>
    <mxCell id="colnote" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#b45309;" value="&lt;b&gt;n1 loaded once&lt;/b&gt;, reused in&#10;all TM cells of its column&#10;→ &lt;b&gt;TM FMAs per load&lt;/b&gt;" vertex="1"><mxGeometry x="396" y="284" width="250" height="40" as="geometry" /></mxCell>
    <mxCell id="tally" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f7f5;strokeColor=#888;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;This 4×4 example:&lt;/b&gt; loads = TM+TN = 8 registers → FMAs = TM×TN = 16.&#10;Each value reused TM or TN times. Kernel's real TM=8,TN=8 → 16 loads → 64 FMAs." vertex="1"><mxGeometry x="146" y="368" width="360" height="58" as="geometry" /></mxCell>
    <mxCell id="why" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" value="&lt;b&gt;Why reuse is valid (not recomputation):&lt;/b&gt;&lt;br&gt;&lt;br&gt;C[i][j] = Σ&lt;sub&gt;k&lt;/sub&gt; A[i][k]·B[k][j].&lt;br&gt;&lt;br&gt;For a fixed k (= dotIdx):&lt;br&gt;• A[i][k] is the SAME value for every output column j → multiply it into the whole regN row.&lt;br&gt;• B[k][j] is the SAME value for every output row i → multiply it into the whole regM column.&lt;br&gt;&lt;br&gt;So one SMEM→register load is consumed by many FMAs. That ratio = arithmetic intensity. Warptiling just widens regM/regN so each load feeds even more FMAs." vertex="1"><mxGeometry x="640" y="120" width="460" height="180" as="geometry" /></mxCell>
  </root>
</mxGraphModel>
