    <mxCell id="title" parent="1" style="text;html=1;align=left;fontSize=14;fontStyle=1;" value="Why the register cache is reusable: matmul is an OUTER PRODUCT (one dotIdx step)" vertex="1"><mxGeometry x="20" y="12" width="1000" height="22" as="geometry" /></mxCell>
    <mxCell id="sub" parent="1" style="text;html=1;align=left;fontSize=10;fontColor=#555;" value="C[i][j] += regM[i] · regN[j].  regM[i] does not depend on j, regN[j] does not depend on i → each loaded value feeds a whole row/column." vertex="1"><mxGeometry x="20" y="36" width="1000" height="16" as="geometry" /></mxCell>
