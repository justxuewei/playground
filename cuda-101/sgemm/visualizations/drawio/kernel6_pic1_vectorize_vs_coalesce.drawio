    <mxCell id="vc_a0" parent="1" style="endArrow=classic;html=1;strokeColor=#b45309;strokeWidth=2;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="520" y="122" as="sourcePoint" /><mxPoint x="520" y="150" as="targetPoint" /></mxGeometry></mxCell>
