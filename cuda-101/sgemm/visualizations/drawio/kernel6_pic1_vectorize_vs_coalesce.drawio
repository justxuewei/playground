    <mxCell id="vc_m1" parent="1" style="whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=7;" value=".y&#10;4B" vertex="1"><mxGeometry x="474" y="150" width="44" height="22" as="geometry" /></mxCell>
    <mxCell id="vc_m2" parent="1" style="whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=7;" value=".z&#10;4B" vertex="1"><mxGeometry x="518" y="150" width="44" height="22" as="geometry" /></mxCell>
    <mxCell id="vc_m3" parent="1" style="whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=7;" value=".w&#10;4B" vertex="1"><mxGeometry x="562" y="150" width="44" height="22" as="geometry" /></mxCell>

    <!-- vector bracket -->
    <mxCell id="vc_grp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#b45309;strokeWidth=2;dashed=1;" value="" vertex="1"><mxGeometry x="426" y="146" width="184" height="30" as="geometry" /></mxCell>
    <mxCell id="vc_res" parent="1" style="text;html=1;align=center;fontSize=10;fontStyle=1;fontColor=#b45309;" value="1 instruction = 4 × 4B = 16 BYTES = 128 BITS" vertex="1"><mxGeometry x="426" y="180" width="240" height="16" as="geometry" /></mxCell>

    <!-- vertical divider -->
    <mxCell id="div" parent="1" style="endArrow=none;html=1;strokeColor=#ccc;strokeWidth=1;dashed=1;" edge="1"><mxGeometry relative="1" as="geometry"><mxPoint x="410" y="55" as="sourcePoint" /><mxPoint x="410" y="210" as="targetPoint" /></mxGeometry></mxCell>

    <!-- ===================== Bottom comparison ===================== -->
    <mxCell id="note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;Watch the units:&lt;/b&gt; coalescing fuses &lt;b&gt;32 threads&lt;/b&gt; into one 128-&lt;b&gt;byte&lt;/b&gt; transaction (hardware, across threads). Vectorize is &lt;b&gt;1 thread&lt;/b&gt; issuing one 128-&lt;b&gt;bit&lt;/b&gt; load (software, within a thread). They compose: 32 vectorized threads still coalesce into 32×16B = 512 B of contiguous traffic." vertex="1">
      <mxGeometry x="20" y="220" width="640" height="56" as="geometry" />
    </mxCell>

  </root>
