    <mxCell id="cl_fuse" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#118a4b;strokeWidth=2;dashed=1;" value="" vertex="1"><mxGeometry x="16" y="146" width="184" height="28" as="geometry" /></mxCell>
    <mxCell id="cl_res" parent="1" style="text;html=1;align=center;fontSize=10;fontStyle=1;fontColor=#118a4b;" value="1 transaction = 32 × 4B = 128 BYTES" vertex="1"><mxGeometry x="16" y="178" width="200" height="16" as="geometry" /></mxCell>

    <!-- ===================== RIGHT: VECTORIZE ===================== -->
    <mxCell id="vc_h" parent="1" style="text;html=1;align=left;fontSize=12;fontStyle=1;fontColor=#b45309;" value="Vectorize — 1 thread × float4" vertex="1">
      <mxGeometry x="430" y="55" width="360" height="18" as="geometry" />
    </mxCell>
    <mxCell id="vc_sub" parent="1" style="text;html=1;align=left;fontSize=9;fontColor=#555;" value="one thread loads 4 consecutive floats in a single instruction" vertex="1">
