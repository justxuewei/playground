    <!-- Bottom take-away spans both -->
    <mxCell id="cmp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;Take-away:&lt;/b&gt; each loaded A row is reused across every B column the thread owns (and vice-versa). 4× outputs per thread costs only ~2× the loads → &lt;b&gt;~1.9× fewer memory accesses per result&lt;/b&gt; (15 → 8)." vertex="1">
