    <mxCell id="fp01" parent="1" style="whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;fontSize=6;fontColor=#5b3a78;" value="8×4" vertex="1"><mxGeometry x="890" y="70" width="11.25" height="22.5" as="geometry" /></mxCell>
